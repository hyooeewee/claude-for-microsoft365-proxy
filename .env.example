KNOWN_MODELS={"claude-opus-4-7":"openrouter/owl-alpha","claude-sonnet-4-6":"nvidia/nemotron-3-super-120b-a12b:free","claude-opus-4-6":"z-ai/glm-4.5-air:free","claude-sonnet-4-5":"openai/gpt-oss-120b:free"}
DEFAULT_MODEL=openrouter/owl-alpha