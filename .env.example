# CORS proxy configuration
ALLOWED_ORIGIN=https://pivot.claude.ai
# [required] The Anthropic base URL of the LLM provider
TARGET_BASE=https://openrouter.ai/api

# Office add-in manifest
GATEWAY_URL=
